        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "afkbushjb49hcd"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH top_names AS (\n  SELECT name\n  FROM events\n  WHERE deleted_at IS NULL\n    AND $__timeFilter(occurred_at)\n  GROUP BY name\n  ORDER BY COUNT(*) DESC\n  LIMIT 10\n)\nSELECT\n  $__timeGroupAlias(e.occurred_at, $__interval),\n  e.name AS metric,\n  COUNT(*)::double precision AS value\nFROM events e\nINNER JOIN top_names t ON t.name = e.name\nWHERE e.deleted_at IS NULL\n  AND $__timeFilter(e.occurred_at)\nGROUP BY 1, 2\nORDER BY 1, 2\n",
          "refId": "A"
        }
      ],
      "title": "Top 10 event names (stacked, by occurred_at)",
      "type": "timeseries"
    },
