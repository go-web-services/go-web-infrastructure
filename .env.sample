# Copy to `.env` for observability compose variable substitution (not mounted into containers).
# Example:
#   docker compose --env-file ./.env -f observability/docker-compose.yml up -d

LOKI_LOG_RETENTION_DAYS=7

GRAFANA_PORT=4001
ALLOY_UI_PORT=4002

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me

GF_SERVER_ROOT_URL=http://localhost:4001
GF_SERVER_SERVE_FROM_SUB_PATH=false
